# =============================================================================
# @file .env.example (Backend)
# @description Fichier d'exemple pour les variables d'environnement du serveur.
# Copiez ce fichier vers .env et remplissez les valeurs réelles.
# =============================================================================

# Port sur lequel le serveur Express va écouter
PORT=5001

# URI de connexion à la base de données MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/scolaris_db

# Secret pour la signature des JSON Web Tokens (JWT) - Utilisez une chaîne complexe
JWT_SECRET=remplace_par_un_secret_tres_fort

# URL du client frontend (pour les politiques CORS)
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Configuration du service d'Email (Nodemailer)
# -----------------------------------------------------------------------------
# Adresse email utilisée pour l'envoi des notifications et OTP
EMAIL_USER=votre-email@gmail.com
# Mot de passe d'application (Généré dans les paramètres de sécurité Google)
EMAIL_PASS=votre-mot-de-passe-application-16-lettres

# -----------------------------------------------------------------------------
# Configuration Cloudinary (Stockage des images/documents dans le cloud)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=dbior6pkb
CLOUDINARY_API_KEY=ta_cle_api
CLOUDINARY_API_SECRET=ton_secret_api
